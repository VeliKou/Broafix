<!DOCTYPE html>
<html lang="fi">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Auton vuokraus - Volkswagen Golf</title>

<style>
body {
  font-family: Arial, sans-serif;
  margin: 0;
  background: #f5f5f5;
}

.container {
  max-width: 900px;
  margin: auto;
  padding: 20px;
}

h1, h2 {
  text-align: center;
}

.card {
  background: white;
  padding: 20px;
  margin-bottom: 20px;
  border-radius: 10px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.price {
  font-size: 24px;
  font-weight: bold;
  color: #2c7a2c;
  text-align: center;
}

input, textarea, button {
  width: 100%;
  padding: 10px;
  margin-top: 10px;
  border-radius: 6px;
  border: 1px solid #ccc;
}

button {
  background-color: #2c7a2c;
  color: white;
  border: none;
  cursor: pointer;
}

button:hover {
  background-color: #256b25;
}

.result {
  margin-top: 10px;
  font-weight: bold;
  color: #2c7a2c;
}

.muted {
  font-size: 13px;
}

.checkbox-row {
  margin-top: 12px;
}

/* ✅ Etusivu nappi */
.back-top {
  position: fixed;
  top: 15px;
  right: 15px;
  background: #2c7a2c;
  color: white;
  padding: 10px 16px;
  border-radius: 20px;
  text-decoration: none;
  font-weight: bold;
}

/* ✅ Vuokrausehdot */
.terms {
  font-size: 13px;
  line-height: 1.5;
}
</style>
</head>

<body>

<!-- ✅ KORJATTU LINKKI -->
<a href="index.html" class="back-top">🏠 Etusivulle</a>

<div class="container">

<h1>Volkswagen Golf 1.6 TDI</h1>

<div class="card">
  <p class="price">30 € / vrk</p>
  <p style="text-align:center;">
    Luotettava ja taloudellinen auto arkeen ja matkalle.
  </p>
</div>

<div class="card">
<h2>Tee varaus</h2>

<!-- ✅ KORJATTU FORM -->
<form action="https://formspree.io/f/xykveewp" method="POST">

<label>Nimi</label>
<input type="text" name="name" required>

<label>Puhelin</label>
<input type="text" name="phone" required>

<label>Sähköposti</label>
<input type="email" name="email" required>

<label>Aloituspäivä</label>
<input type="date" id="start" onchange="laskeHinta()" required>

<label>Luovutusaika</label>
<input type="time" id="start_time" onchange="laskeHinta()" required>

<label>Lopetuspäivä</label>
<input type="date" id="end" onchange="laskeHinta()" required>

<label>Palautusaika</label>
<input type="time" id="end_time" onchange="laskeHinta()" required>

<div class="result" id="tulos"></div>

<label>Lisätiedot</label>
<textarea name="message"></textarea>

<div class="checkbox-row">
  <input type="checkbox" required>
  Hyväksyn <a href="#vuokrausehdot">vuokrausehdot</a>
</div>

<button type="submit">Lähetä varauspyyntö</button>
</form>

<p class="muted">
Varaus vahvistetaan erikseen. Maksu ennen luovutusta.
</p>

</div>

<!-- ✅ LYHENNETYT VUOKRAUSEHDOT -->
<div class="card terms" id="vuokrausehdot">
<h2>Vuokrausehdot (lyhyesti)</h2>

<ol>
<li><b>Varaus:</b> Varaus vahvistuu maksun jälkeen.</li>
<li><b>Käyttö:</b> Vain normaali ajo, ei tupakointia tai rikkomuksia.</li>
<li><b>Omavastuu:</b> max 500 € vahingoista.</li>
<li><b>Polttoaine:</b> Palauta samalla tasolla.</li>
<li><b>Myöhästyminen:</b> 10 € / tunti.</li>
<li><b>Sakot:</b> Vuokraaja maksaa kaikki sakot.</li>
<li><b>Peruutus:</b> Alle 6h ennen → 20 €.</li>
<li><b>Tiedot:</b> Käytetään vain vuokraukseen.</li>
</ol>

</div>

</div>

<script>
function laskeHinta() {
  const alkuPvm = document.getElementById("start").value;
  const loppuPvm = document.getElementById("end").value;
  const alkuAika = document.getElementById("start_time").value;
  const loppuAika = document.getElementById("end_time").value;

  if (!alkuPvm || !loppuPvm || !alkuAika || !loppuAika) {
    document.getElementById("tulos").innerText = "";
    return;
  }

  const alku = new Date(alkuPvm + "T" + alkuAika);
  const loppu = new Date(loppuPvm + "T" + loppuAika);

  const ero = loppu - alku;

  if (ero <= 0) {
    document.getElementById("tulos").innerText = "Tarkista päivämäärät";
    return;
  }

  const paivat = Math.ceil(ero / (1000 * 60 * 60 * 24));
  const hinta = paivat * 30;

  document.getElementById("tulos").innerText =
    "Vuokra-aika: " + paivat + " päivää | Hinta: " + hinta + " €";
}
</script>

</body>
</html>
